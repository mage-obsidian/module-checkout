<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:Module/etc/module.xsd">
    <module name="MageObsidian_Checkout">
        <sequence>
            <!-- Builds on the storefront foundation: reuses its cart primitives
                 (the mini-cart imports MageObsidian_Storefront::js/useCart and the
                 shared Drawer) and inherits its legacy-layout neutralization. -->
            <module name="MageObsidian_Storefront"/>
            <module name="MageObsidian_ModernFrontend"/>
            <!-- Load after the core checkout module whose frontend this adapts, so
                 our re-declared layout wins the merge. -->
            <module name="Magento_Checkout"/>
        </sequence>
    </module>
</config>
