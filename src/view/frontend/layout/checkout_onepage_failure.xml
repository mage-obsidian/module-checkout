<?xml version="1.0"?>
<!--
  Re-declares the suppressed core failure page, reusing the native Onepage\Failure
  block (real order id + error message + continue URL) through our Twig.
  Order-specific, so not cacheable.
-->
<page layout="1column" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <head>
        <title>The order was not successful</title>
    </head>
    <body>
        <referenceBlock name="page.main.title" remove="true"/>
        <referenceContainer name="content">
            <block class="Magento\Checkout\Block\Onepage\Failure" name="checkout.failure"
                   template="Magento_Checkout::onepage/failure.twig" cacheable="false"/>
        </referenceContainer>
    </body>
</page>
